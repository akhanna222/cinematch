# CineMatch backend configuration. Copy to `.env` and adjust.
# All vars are prefixed CINEMATCH_.

CINEMATCH_ENVIRONMENT=development
CINEMATCH_DEBUG=true

# --- Persistence ---
# Local dev default is SQLite; point at Postgres in any shared environment.
# CINEMATCH_DATABASE_URL=postgresql+psycopg://cinematch:cinematch@localhost:5432/cinematch
CINEMATCH_DATABASE_URL=sqlite:///./cinematch.db
CINEMATCH_REDIS_URL=redis://localhost:6379/0

# --- Auth ---
CINEMATCH_JWT_SECRET=change-me-to-a-long-random-string
CINEMATCH_ACCESS_TOKEN_TTL_MINUTES=10080

# --- Integrations (PRD §13) ---
CINEMATCH_TMDB_API_KEY=
CINEMATCH_JUSTWATCH_ENABLED=false
CINEMATCH_STREAMING_CACHE_TTL_SECONDS=86400

# --- Model weights (PRD §14.3, must sum to 1.0) ---
CINEMATCH_WEIGHT_GENRE_OVERLAP=0.30
CINEMATCH_WEIGHT_FAVOURITE_OVERLAP=0.35
CINEMATCH_WEIGHT_RATING_CORRELATION=0.25
CINEMATCH_WEIGHT_WATCHLIST_OVERLAP=0.10
